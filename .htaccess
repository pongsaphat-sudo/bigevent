DirectoryIndex index.php
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^favicon\.ico$ /assets/img/favicon.svg [L]
    RewriteRule ^wp-content/uploads/.*\.(jpe?g|png|gif|webp|svg)$ /assets/img/og-default.png [L,NC]
    RewriteRule ^ index.php [L]
</IfModule>
